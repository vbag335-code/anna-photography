# ── Sanity ────────────────────────────────────────────────────────────────────
# Your Sanity project ID.
# Find it: sanity.io/manage → your project → top of the page (looks like: abc12def)
NEXT_PUBLIC_SANITY_PROJECT_ID=

# The Sanity dataset name. Almost always "production" unless you created a custom one.
NEXT_PUBLIC_SANITY_DATASET=production

# A Sanity API token with READ permissions.
# Create one: sanity.io/manage → your project → API → Tokens → Add API token → Viewer
# This lets Next.js pull content server-side without going through the CDN cache.
SANITY_API_READ_TOKEN=
